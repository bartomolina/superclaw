# Convex deployment selection
CONVEX_DEPLOYMENT=dev:your-convex-deployment

# Convex endpoints for this deployment
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Canonical app URL (must match Convex SITE_URL)
# Local single-machine example:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Private internal/Tailscale example:
# NEXT_PUBLIC_SITE_URL=http://100.101.249.4:4100
# Production example:
# NEXT_PUBLIC_SITE_URL=https://kanban.example.com

# Used by runtime-backed kanban agent endpoints
GATEWAY_TOKEN=your-gateway-token

# Optional: override OpenClaw home directory (default: ~/.openclaw)
# OPENCLAW_HOME=/home/your-user/.openclaw

# Convex env vars are set with `pnpm exec convex env set ...`:
# - BETTER_AUTH_SECRET
# - SITE_URL
# - SUPERUSER_EMAIL (the only superuser allowed to administer the app)
# - RESEND_API_KEY
# - AUTH_FROM_EMAIL
# - TRUSTED_ORIGINS (optional, comma-separated)
# - MAGIC_LINK_EMAIL_COOLDOWN_MS (optional, default 120000)
# - MAGIC_LINK_GLOBAL_COOLDOWN_MS (optional, default 5000)
# - KANBAN_AGENT_SHARED_TOKEN (shared secret for agent API auth)
