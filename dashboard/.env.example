# OpenClaw gateway token (also used as dashboard login password)
GATEWAY_TOKEN=your-gateway-token-here

# Optional: override OpenClaw home directory (default: ~/.openclaw)
# OPENCLAW_HOME=/root/.openclaw

# Optional: Gemini API key for avatar generation
# GEMINI_API_KEY=

# Optional: prepend custom path containing `uv` binary (default: ~/.local/bin)
# UV_PATH=/root/.local/bin

# Optional: enable raw debug RPC endpoint (/api/debug/ws). Disabled by default.
# DEBUG_RPC_ENABLED=false
